{
  "type": "module",
  "name": "typescript-actions",
  "version": "1.0.0",
  "description": "Composite actions developed in TypeScript to use in GitHub Actions workflows.",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alextheman231/typescript-actions.git"
  },
  "sideEffects": true,
  "scripts": {
    "build": "tsdown",
    "build-configs": "tsdown --config tsdown.configs.config.ts",
    "format": "pnpm run format-prettier && pnpm run format-eslint",
    "format-eslint": "eslint --fix --suppress-all package.json \"{src,configs}/**/*.ts\" && rm -f eslint-suppressions.json",
    "format-prettier": "pnpm run format-prettier-typescript && pnpm run format-prettier-javascript",
    "format-prettier-javascript": "prettier --write \"**/*.{js,json}\"",
    "format-prettier-typescript": "prettier --parser typescript --write \"**/*.ts\"",
    "lint": "pnpm run lint-eslint && pnpm run lint-prettier",
    "lint-eslint": "eslint package.json \"{src,configs}/**/*.ts\"",
    "lint-prettier": "pnpm run lint-prettier-javascript",
    "lint-prettier-javascript": "prettier --check \"**/*.{js,json}\"",
    "lint-prettier-typescript": "prettier --parser typescript --check \"**/*.ts\"",
    "pre-commit": "pnpm run build-configs && alex-c-line pre-commit",
    "prepare": "husky",
    "test": "exit 0"
  },
  "author": "alextheman",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "devDependencies": {
    "@alextheman/eslint-plugin": "5.11.0",
    "@types/node": "25.5.0",
    "alex-c-line": "2.4.1",
    "eslint": "10.1.0",
    "husky": "9.1.7",
    "prettier": "3.8.1",
    "tsdown": "0.21.7",
    "typescript": "6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "@alextheman/utility": "5.9.0",
    "execa": "9.6.1",
    "zod": "4.3.6"
  }
}
