{
  "type": "module",
  "name": "typescript-actions",
  "version": "1.2.1",
  "description": "Composite actions developed in TypeScript to use in GitHub Actions workflows.",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alextheman231/typescript-actions.git"
  },
  "sideEffects": true,
  "scripts": {
    "build": "tsdown",
    "build-configs": "tsdown --config tsdown.configs.config.ts",
    "create-release-note": "bash -c 'git pull origin main && alex-c-line template release-note create $@' --",
    "format": "pnpm run format-prettier && pnpm run format-eslint",
    "format-eslint": "eslint --fix --suppress-all package.json \"{src,configs}/**/*.ts\" && rm -f eslint-suppressions.json",
    "format-prettier": "pnpm run format-prettier-typescript && pnpm run format-prettier-javascript && pnpm run format-prettier-yml",
    "format-prettier-javascript": "prettier --write \"**/*.{js,json}\"",
    "format-prettier-typescript": "prettier --parser typescript --write \"**/*.ts\"",
    "format-prettier-yml": "prettier --write \"**/*.{yaml,yml}\"",
    "lint": "pnpm run lint-tsc && pnpm run lint-eslint && pnpm run lint-prettier",
    "lint-eslint": "eslint package.json \"{src,configs}/**/*.ts\"",
    "lint-prettier": "pnpm run lint-prettier-typescript && pnpm run lint-prettier-javascript && pnpm run lint-prettier-yml",
    "lint-prettier-javascript": "prettier --check \"**/*.{js,json}\"",
    "lint-prettier-typescript": "prettier --parser typescript --check \"**/*.ts\"",
    "lint-prettier-yml": "prettier --check \"**/*.{yaml,yml}\"",
    "lint-tsc": "tsc --noEmit",
    "pre-commit": "pnpm run build-configs && alex-c-line pre-commit",
    "prepare": "husky",
    "test": "vitest run",
    "test-watch": "vitest",
    "update-dependencies": "pnpm update --latest && pnpm update"
  },
  "author": "alextheman",
  "license": "ISC",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "devDependencies": {
    "@alextheman/eslint-plugin": "5.14.0",
    "@types/node": "25.6.0",
    "alex-c-line": "2.7.2",
    "eslint": "10.3.0",
    "husky": "9.1.7",
    "prettier": "3.8.3",
    "tsdown": "0.21.10",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@alextheman/utility": "5.16.1",
    "execa": "9.6.1",
    "zod": "4.4.2"
  }
}
